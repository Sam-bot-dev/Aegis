# ======================================================================
# AEGIS — Environment Variables Template
# ======================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env (it's in .gitignore).
# Each service will load this via pydantic-settings.
# ======================================================================

# ---------- Environment ----------
AEGIS_ENV=local                      # local | dev | staging | prod
AEGIS_LOG_LEVEL=DEBUG                # DEBUG | INFO | WARNING | ERROR

# ---------- Google Cloud ----------
GCP_PROJECT_ID=aegis-prod-xxxx       # your GCP project id (see SETUP.md)
GCP_REGION=asia-south1               # Mumbai region (fast for India)
GOOGLE_APPLICATION_CREDENTIALS=./.secrets/service-account.json
                                     # path to your service-account JSON key

# ---------- Vertex AI / Gemini ----------
VERTEX_AI_LOCATION=asia-south1       # region for Vertex AI calls
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_FLASH_MODEL=gemini-2.5-flash
MEDGEMMA_ENDPOINT=                   # fill in after deploying MedGemma (P1)

# Optional: for quick local testing with Gemini Developer API
# (Vertex AI is the production path; this is just for speed-dev)
GOOGLE_API_KEY=                      # https://aistudio.google.com/apikey

# ---------- Firebase ----------
FIREBASE_PROJECT_ID=aegis-prod-xxxx  # usually same as GCP_PROJECT_ID
FIREBASE_ADMIN_CREDENTIALS=./.secrets/firebase-adminsdk.json

# ---------- Firestore ----------
FIRESTORE_EMULATOR_HOST=             # set to 127.0.0.1:8080 for local emulator
FIRESTORE_DATABASE=(default)

# ---------- Pub/Sub ----------
PUBSUB_EMULATOR_HOST=                # set to 127.0.0.1:8085 for local emulator
PUBSUB_TOPIC_RAW_FRAMES=raw-frames
PUBSUB_TOPIC_AUDIO=audio-chunks
PUBSUB_TOPIC_SENSORS=sensor-events
PUBSUB_TOPIC_PERCEPTUAL=perceptual-signals
PUBSUB_TOPIC_INCIDENTS=incident-events
PUBSUB_TOPIC_DISPATCH=dispatch-events
PUBSUB_TOPIC_AUDIT=audit-events

# ---------- Cloud Storage ----------
STORAGE_BUCKET_EVIDENCE=aegis-evidence-local
STORAGE_BUCKET_REPORTS=aegis-reports-local
STORAGE_BUCKET_ASSETS=aegis-venue-assets-local

# ---------- BigQuery ----------
BQ_DATASET_AUDIT=aegis_audit
BQ_DATASET_ANALYTICS=aegis_analytics
BQ_DATASET_LEARNING=aegis_learning

# ---------- Service URLs (local) ----------
INGEST_SERVICE_URL=http://127.0.0.1:8001
VISION_SERVICE_URL=http://127.0.0.1:8002
ORCHESTRATOR_SERVICE_URL=http://127.0.0.1:8003
DISPATCH_SERVICE_URL=http://127.0.0.1:8004

# ---------- External integrations (P1, leave blank for now) ----------
MSG91_AUTH_KEY=                      # SMS (India) — later
SENDGRID_API_KEY=                    # Email — later

# ---------- Maps ----------
GOOGLE_MAPS_API_KEY=                 # for web dashboard & Flutter apps

# ---------- Security ----------
SERVICE_INTERNAL_SECRET=change-me    # HMAC for service-to-service when not using IAM
WEBHOOK_SIGNING_KEY=                 # authority webhook Ed25519 key (generate)
